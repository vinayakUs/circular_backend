{"type":"excalidraw","version":2,"source":"https://excalidraw.com","elements":[
  {"type":"text","id":"title","x":400,"y":20,"width":700,"height":40,"fontSize":32,"fontFamily":1,"text":"Regulatory RAG Pipeline - Retrieval Architecture","textAlign":"center","verticalAlign":"middle","baseline":160,"roughness":0,"roundness":null,"strokeStyle":"solid"},
  {"type":"text","id":"subtitle","x":400,"y":55,"width":700,"height":20,"fontSize":14,"fontFamily":1,"text":"Hybrid Search (BM25 + KNN) → RRF Fusion → LLM Answer Generation","textAlign":"center","verticalAlign":"middle","baseline":160,"roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"ellipse","id":"user","x":60,"y":100,"width":180,"height":80,"strokeColor":"#1e1e1e","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#e3f2fd","roughness":0,"roundness":{"type":2},"boundElements":[{"type":"text","id":"user-text"}]},
  {"type":"text","id":"user-text","x":60,"y":100,"width":180,"height":80,"fontSize":14,"fontFamily":1,"text":"User Query\n\n• Natural language\n• Regulatory question\n• Compliance inquiry","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"user","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"api","x":300,"y":100,"width":180,"height":100,"strokeColor":"#6a1b9a","strokeWidth":3,"fillStyle":"solid","backgroundColor":"#ede7f6","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"api-text"}]},
  {"type":"text","id":"api-text","x":300,"y":100,"width":180,"height":100,"fontSize":13,"fontFamily":1,"text":"Flask API\n\n• GET /search?q=&strategy=\n• Query validation\n• Metadata filters (exchange)\n• strategy: bm25|vector|hybrid","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"api","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"query-embed","x":540,"y":100,"width":180,"height":80,"strokeColor":"#0277bd","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#e1f5fe","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"query-embed-text"}]},
  {"type":"text","id":"query-embed-text","x":540,"y":100,"width":180,"height":80,"fontSize":12,"fontFamily":1,"text":"EmbeddingProvider\n\n• Model: BAAI/bge-base-en-v1.5\n• 768 dimensions\n• Query instruction prefix\n• L2 normalization\n• embed_query() for search","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"query-embed-text","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"bm25-search","x":800,"y":80,"width":200,"height":130,"strokeColor":"#2e7d32","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#e8f5e9","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"bm25-search-text"}]},
  {"type":"text","id":"bm25-search-text","x":800,"y":80,"width":200,"height":130,"fontSize":11,"fontFamily":1,"text":"BM25 Search\n\n• circular_id boost: 5 (exact)\n• chunk_text_contextual boost: 3\n• multi_match: chunk_text^2,\n  title^2, full_reference^2,\n  department(1), source(1)\n• tie_breaker: 0.3\n• Size: 40 (RRF window: 50)","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"bm25-search","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"knn-search","x":800,"y":230,"width":200,"height":100,"strokeColor":"#0277bd","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#e1f5fe","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"knn-search-text"}]},
  {"type":"text","id":"knn-search-text","x":800,"y":230,"width":200,"height":100,"fontSize":12,"fontFamily":1,"text":"KNN Search (Vector)\n\n• Field: embedding (768 dims)\n• Cosine similarity\n• num_candidates: max(size*3, 50)\n• size=40 (search) / 50 (RRF)\n• Parallel to BM25","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"knn-search","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"rrf-fusion","x":800,"y":350,"width":200,"height":120,"strokeColor":"#ad1457","strokeWidth":3,"fillStyle":"solid","backgroundColor":"#f8bbd0","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"rrf-fusion-text"}]},
  {"type":"text","id":"rrf-fusion-text","x":800,"y":350,"width":200,"height":120,"fontSize":12,"fontFamily":1,"text":"RRF Fusion (ranx library)\n\n• Separate BM25 + KNN runs\n• rrf([bm25_run, knn_run], k=60)\n• Formula: 1/(k_const + rank)\n• k_const=60 (ES_RRF_RANK_CONSTANT)\n• Returns top 40 fused hits\n• ranx.Run objects","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"rrf-fusion","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"search-hit","x":800,"y":490,"width":200,"height":120,"strokeColor":"#e65100","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#fff3e0","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"search-hit-text"}]},
  {"type":"text","id":"search-hit-text","x":800,"y":490,"width":200,"height":120,"fontSize":11,"fontFamily":1,"text":"SearchHit + Preview\n\n• es_id, score, document\n• SearchHit.build_preview(query)\n• multi_snippet(text, query,\n  window=120, merge_gap=80)\n• highlight(snippet, query)\n  → <mark>term</mark> HTML\n• Returns list[SearchHit]","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"search-hit","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"rag-llm","x":300,"y":230,"width":180,"height":100,"strokeColor":"#c62828","strokeWidth":3,"fillStyle":"solid","backgroundColor":"#ffebee","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"rag-llm-text"}]},
  {"type":"text","id":"rag-llm-text","x":300,"y":230,"width":180,"height":100,"fontSize":12,"fontFamily":1,"text":"RAGAnswerGenerator\n\n• Model: minimax-m2.7\n• Max tokens: 4000\n• Max chunks: 10\n• _build_context_chunks()\n• _build_prompt()\n• response_model=RAGAnswer","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"rag-llm","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"response","x":60,"y":230,"width":180,"height":100,"strokeColor":"#1e1e1e","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#e3f2fd","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"response-text"}]},
  {"type":"text","id":"response-text","x":60,"y":230,"width":180,"height":100,"fontSize":12,"fontFamily":1,"text":"API Response\n\n• strategy=bm25: results[]\n  with preview + document\n• strategy=hybrid|vector:\n  answer + references\n  + snippets\n• rag_error fallback","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"response","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"llm-prompt","x":300,"y":380,"width":180,"height":130,"strokeColor":"#c62828","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#ffebee","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"llm-prompt-text"}]},
  {"type":"text","id":"llm-prompt-text","x":300,"y":380,"width":180,"height":130,"fontSize":11,"fontFamily":1,"text":"LLM Prompt Template\n\n• System: regulatory expert\n• User question + context chunks\n• Guidelines:\n  - Answer comprehensively\n  - Cite specific circular_id\n  - Extract relevant snippets\n  - Be factual, no hallucination\n  - Structured output","textAlign":"center","verticalAlign":null,"baseline":160,"containerId":"llm-prompt","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"nvidia","x":60,"y":380,"width":180,"height":80,"strokeColor":"#c62828","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#ffebee","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"nvidia-text"}]},
  {"type":"text","id":"nvidia-text","x":60,"y":380,"width":180,"height":80,"fontSize":12,"fontFamily":1,"text":"NVIDIA API\n\n• minimax-m2.7 via NVIDIA\n• Structured output (Pydantic)\n• RAGAnswer response model\n• Answer + Citations + Snippets","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"nvidia","roughness":0,"roundness":null,"strokeStyle":"solid"},

  {"type":"rectangle","id":"es-index","x":540,"y":420,"width":200,"height":140,"strokeColor":"#2e7d32","strokeWidth":2,"fillStyle":"solid","backgroundColor":"#e8f5e9","roughness":0,"roundness":{"type":3},"boundElements":[{"type":"text","id":"es-index-text"}]},
  {"type":"text","id":"es-index-text","x":540,"y":420,"width":200,"height":140,"fontSize":11,"fontFamily":1,"text":"ES Index Schema\n\n• Index: circulars_chunks\n• chunk_id (keyword)\n• chunk_text (text)\n• chunk_text_contextual (text)\n• embedding (768 dims, dense)\n• circular_id, title,\n  full_reference, source\n• issue_date, effective_date","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"es-index","roughness":0,"roundness":null,"strokeStyle":"solid"},

