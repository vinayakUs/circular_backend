  {"type":"text","id":"chunk-detail-text","x":540,"y":260,"width":200,"height":130,"fontSize":11,"fontFamily":1,"text":"Chunk Document\n\n• chunk_id (SHA1, keyword)\n• chunk_index, chunk_text\n• chunk_text_contextual\n• embedding (768 dims)\n• circular_db_id, asset_id\n• source, title, department\n• full_reference, url, pdf_url","textAlign":"center","verticalAlign":"middle","baseline":160,"containerId":"chunk-detail","roughness":0,"roundness":null,"strokeStyle":"solid"},

