    {"type": "text", "id": "subtitle", "x": 400, "y": 55, "width": 700, "height": 20, "fontSize": 14, "fontFamily": 1, "text": "Elasticsearch Hybrid Search + RRF Reranking + LLM Answer Generation", "textAlign": "center", "verticalAlign": "middle", "baseline": 160, "roughness": 0, "roundness": null, "strokeStyle": "solid"},

    {"type": "rectangle", "id": "sources", "x": 60, "y": 100, "width": 200, "height": 120, "strokeColor": "#1e1e1e", "strokeWidth": 2, "fillStyle": "solid", "backgroundColor": "#e3f2fd", "roughness": 0, "roundness": {"type": 3}, "boundElements": [{"type": "text", "id": "sources-text"}]},
