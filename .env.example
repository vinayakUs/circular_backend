FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key
LOG_LEVEL=INFO
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/circular_backend
DB_MIN_SIZE=1
DB_MAX_SIZE=5
SEBI_DETAIL_TIMEOUT_SECONDS=30
SEBI_DETAIL_MAX_RETRIES=3
SEBI_DETAIL_RETRY_BACKOFF_SECONDS=2
SCRAPER_ENABLED_SOURCES=NSE,SEBI,BSE
